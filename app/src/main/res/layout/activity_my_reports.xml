<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050818">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1A1F3D"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="24dp"
            android:layout_toEndOf="@id/btnBack"
            android:text="My Reports"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Tabs -->
    <LinearLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Reports"
                android:textColor="#4285F4"
                android:textSize="16sp" />
            <View
                android:layout_width="100dp"
                android:layout_height="3dp"
                android:layout_marginTop="4dp"
                android:background="#4285F4" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/tabLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card 1: Flooding -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/grid_item_bg"
                android:padding="16dp">

                <TextView
                    android:id="@+id/status1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_rounded_gray"
                    android:backgroundTint="#FF5252"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Reported"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/title1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/status1"
                    android:layout_marginTop="8dp"
                    android:text="FLOODING"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/loc1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/title1"
                    android:text="Main Building . Floor 3 . Room 305"
                    android:textColor="#BDBDBD"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/btnMarkFixed1"
                        android:layout_width="24dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Mark Fixed"
                        android:src="@drawable/ic_check"
                        app:tint="#4285F4" />

                    <TextView android:id="@+id/btnEditReport1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="×" android:textColor="@color/white" android:textSize="24sp" android:layout_marginEnd="8dp"/>

                    <ImageView
                        android:id="@+id/btnDeleteReport1"
                        android:layout_width="28dp"
                        android:layout_height="match_parent"
                        android:contentDescription="Delete"
                        android:src="@drawable/ic_delete" />
                </LinearLayout>

                <TextView
                    android:id="@+id/time1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/loc1"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="12dp"
                    android:text="2 days ago"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp" />
            </RelativeLayout>


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/grid_item_bg"
                android:padding="16dp">

                <TextView
                    android:id="@+id/status2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_rounded_gray"
                    android:backgroundTint="#FBC02D"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Under Review"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/title2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/status2"
                    android:layout_marginTop="8dp"
                    android:text="SPILLED LIQUID"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/loc2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/title2"
                    android:text="Dance Studio . Floor 6"
                    android:textColor="#BDBDBD"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal">
                    <ImageView android:id="@+id/btnMarkFixed2" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_check" app:tint="#4285F4" android:layout_marginEnd="8dp" android:contentDescription="Mark Fixed"/>
                    <TextView android:id="@+id/btnEditReport2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="×" android:textColor="@color/white" android:textSize="24sp" android:layout_marginEnd="8dp"/>
                    <ImageView android:id="@+id/btnDeleteReport2" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_delete" android:contentDescription="Delete"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/time2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/loc2"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="12dp"
                    android:text="4 days ago"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp" />
            </RelativeLayout>


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/grid_item_bg"
                android:padding="16dp">

                <TextView
                    android:id="@+id/status3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_rounded_gray"
                    android:backgroundTint="#4CAF50"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Resolved"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/title3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/status3"
                    android:layout_marginTop="8dp"
                    android:text="TV WON'T OPEN"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/loc3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/title3"
                    android:text="Floor 4 . Room 404"
                    android:textColor="#BDBDBD"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal">
                    <ImageView android:id="@+id/btnMarkFixed3" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_check" app:tint="#4285F4" android:layout_marginEnd="8dp" android:contentDescription="Mark Fixed"/>
                    <TextView android:id="@+id/btnEditReport3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="×" android:textColor="@color/white" android:textSize="24sp" android:layout_marginEnd="8dp"/>
                    <ImageView android:id="@+id/btnDeleteReport3" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_delete" android:contentDescription="Delete"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/time3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/loc3"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="12dp"
                    android:text="14 hours ago"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp" />
            </RelativeLayout>


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/grid_item_bg"
                android:padding="16dp">

                <TextView
                    android:id="@+id/status4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_rounded_gray"
                    android:backgroundTint="#FFD54F"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="In Progress"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/title4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/status4"
                    android:layout_marginTop="8dp"
                    android:text="AIRCON MALFUNCTION"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/loc4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/title4"
                    android:text="Science Lab . Floor 4 . Room 408"
                    android:textColor="#BDBDBD"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView android:id="@+id/btnMarkFixed4" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_check" app:tint="#4285F4" android:contentDescription="Mark Fixed"/>
                    <TextView android:id="@+id/btnEditReport4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="×" android:textColor="@color/white" android:textSize="20sp" />
                    <ImageView android:id="@+id/btnDeleteReport4" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_delete" android:contentDescription="Delete"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/time4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/loc4"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="12dp"
                    android:text="1 hours ago"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>


    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bottom_nav_rounded_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Home"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/white"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReports"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_reports"
                android:contentDescription="Reports"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reports"
                android:textColor="#4285F4"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAdd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_add_circle"
                app:tint="#FFFFFF"
                android:contentDescription="Add"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add"
                android:textColor="@color/white"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navMaps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_location"
                android:contentDescription="Maps"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maps"
                android:textColor="@color/white"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="@color/white"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
