<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/top_bar_bg"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/top_bar_text"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="24dp"
            android:layout_toEndOf="@id/btnBack"
            android:text="Nearby Reports"
            android:textColor="@color/top_bar_text"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Floor Filters -->
    <HorizontalScrollView
        android:id="@+id/floorFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFilterAllFloors"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="All Floors"
                android:backgroundTint="@color/card_bg"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:paddingHorizontal="16dp"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btnFilterFloor1"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="Floor 1"
                android:backgroundTint="@color/btn_gray"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:paddingHorizontal="16dp"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btnFilterFloor2"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="Floor 2"
                android:backgroundTint="@color/card_bg"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:paddingHorizontal="16dp"
                app:cornerRadius="8dp" />


        </LinearLayout>
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/floorFilters">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Map View Placeholder -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/global" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#44000000" />
                <!-- Google Logo Placeholder -->
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="8dp"
                    android:src="@drawable/google_logo" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Nearby Report 1 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/grid_item_bg"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/stat_sys_warning"
                        app:tint="#FBC02D" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/icon1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvReportTitle1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FLOODING"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvReportLocation1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Main Building . Floor 3 . Room 305"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvReportStatus1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/button_rounded_gray"
                            android:backgroundTint="#FF5252"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="2dp"
                            android:text="Status: Pending"
                            android:textColor="@color/text_primary"
                            android:textSize="10sp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvReportTime1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:text="10 mins ago"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />
                </RelativeLayout>


                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/grid_item_bg"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_fire" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/icon2"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvReportTitle2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ELECTRIC FIRE"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvReportLocation2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Computer Lab . Floor 6 . Room 601"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvReportStatus2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/button_rounded_gray"
                            android:backgroundTint="#4CAF50"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="2dp"
                            android:text="Status: Resolved"
                            android:textColor="@color/text_primary"
                            android:textSize="10sp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvReportTime2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:text="12 mins ago"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />
                </RelativeLayout>


                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/grid_item_bg"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon3"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="@color/text_primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/icon3"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvReportTitle3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ELEVATOR MALFUNCTION"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvReportLocation3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Main Building . Floor 2 . Near at boys restroom"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvReportStatus3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/button_rounded_gray"
                            android:backgroundTint="#FF5252"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="2dp"
                            android:text="Status: Pending"
                            android:textColor="@color/text_primary"
                            android:textSize="10sp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvReportTime3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:text="5 mins ago"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />
                </RelativeLayout>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/btnNearbyView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="View"
                        android:backgroundTint="#757575"
                        android:textAllCaps="false"
                        android:layout_marginEnd="4dp"
                        app:cornerRadius="4dp" />
                    <Button
                        android:id="@+id/btnNearbyEdit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Edit"
                        android:backgroundTint="#757575"
                        android:textAllCaps="false"
                        android:layout_marginHorizontal="4dp"
                        app:cornerRadius="4dp" />
                    <Button
                        android:id="@+id/btnNearbyDelete"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Delete"
                        android:backgroundTint="#FF5252"
                        android:textAllCaps="false"
                        android:layout_marginStart="4dp"
                        app:cornerRadius="4dp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bottom_nav_rounded_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/nav_icon_tint"
                android:contentDescription="Home"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/nav_text_color"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReports"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_reports"
                app:tint="@color/nav_icon_tint"
                android:contentDescription="Reports"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reports"
                android:textColor="@color/nav_text_color"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAdd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_add_circle"
                app:tint="@color/nav_icon_tint"
                android:contentDescription="Add"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add"
                android:textColor="@color/nav_text_color"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navMaps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_location"
                app:tint="@color/nav_selected"
                android:contentDescription="Maps"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maps"
                android:textColor="@color/nav_selected"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/nav_icon_tint"
                android:contentDescription="Settings"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="@color/nav_text_color"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
